# =============================================================================
# HNAG — Environment variables
# Full list and rules: docs/tech-spec.md Section 05b (Environment Variables)
# Copy to .env.local — never commit .env or .env.local
# =============================================================================
# Vite exposes only env vars prefixed with VITE_ to the client.
# Public (browser) — for this Vite app use VITE_ prefix:
# VITE_SUPABASE_URL=       # Supabase project URL (Project Settings → API)
# VITE_SUPABASE_ANON_KEY=  # Supabase anon/public key (Project Settings → API)
#
# (Astro/Next use PUBLIC_ or NEXT_PUBLIC_)
# PUBLIC_CLOUDFLARE_R2_CDN_URL=
# VAPID_PUBLIC_KEY=
# PUBLIC_POSTHOG_KEY=
# PUBLIC_POSTHOG_HOST=

# Server-only (never PUBLIC_)
# SUPABASE_SERVICE_ROLE_KEY=
# GEMINI_API_KEY=
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# PAYOS_CLIENT_ID=
# PAYOS_API_KEY=
# PAYOS_CHECKSUM_KEY=
# CLOUDFLARE_R2_* (account, bucket, keys)
# RESEND_API_KEY=
# RESEND_FROM_ADDRESS=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=
# SENTRY_DSN=
# SUPABASE_WEBHOOK_SECRET=

# =============================================================================
# MCP (Cursor) — for .cursor/mcp.json only; add to .gitignore
# =============================================================================
# SUPABASE_PERSONAL_ACCESS_TOKEN=
# SUPABASE_DEV_PROJECT_REF=
# VERCEL_TOKEN=  # if using Vercel MCP
