# =============================================================================
# HNAG — Environment variables
# Full list and rules: docs/tech-spec.md Section 05b (Environment Variables)
# Copy to .env.local — never commit .env or .env.local
# =============================================================================
# Vite exposes only env vars prefixed with VITE_ to the browser. For Astro/Next
# use PUBLIC_ or NEXT_PUBLIC_. No secrets in client-exposed vars.

# -----------------------------------------------------------------------------
# Public (browser) — Vite: use VITE_ prefix
# -----------------------------------------------------------------------------
# Supabase (client-safe anon key)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# R2 CDN URL for dish images and avatars (e.g. https://assets.hnag.vn)
PUBLIC_CLOUDFLARE_R2_CDN_URL=

# Web Push (Service Worker)
VAPID_PUBLIC_KEY=

# PostHog analytics
PUBLIC_POSTHOG_KEY=
PUBLIC_POSTHOG_HOST=

# -----------------------------------------------------------------------------
# Server-only — never use PUBLIC_/VITE_ for these
# -----------------------------------------------------------------------------
# Supabase service role — bypasses RLS; server-side only
SUPABASE_SERVICE_ROLE_KEY=

# LLM (Gemini 2.5 Flash — adaptation copy, pantry NLP)
GEMINI_API_KEY=

# Upstash Redis — deck cache, adaptation cache, rate limit
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# PayOS — create order, webhook HMAC verification (set in .env.local; never commit real keys)
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=

# App origin for payment return/cancel URLs (e.g. https://hnag.vn or http://localhost:5173)
APP_URL=

# Cloudflare R2 — image pipeline and avatar upload
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET_NAME=

# Resend — receipts, onboarding emails
RESEND_API_KEY=
RESEND_FROM_ADDRESS=

# Web Push (server)
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=

# Sentry — LLM failures, Rule Engine, webhook errors
SENTRY_DSN=

# Supabase DB webhooks (optional — Background Jobs)
SUPABASE_WEBHOOK_SECRET=

# Cron job auth (optional — for POST /api/cron/care-days)
CRON_SECRET=

# -----------------------------------------------------------------------------
# Image pipeline only (admin/local)
# -----------------------------------------------------------------------------
# Nano Banana — offline admin-only; never in production env
# NANO_BANANA_API_KEY=

# -----------------------------------------------------------------------------
# MCP (Cursor) — for .cursor/mcp.json only; add to .gitignore
# -----------------------------------------------------------------------------
# SUPABASE_PERSONAL_ACCESS_TOKEN=
# SUPABASE_DEV_PROJECT_REF=
# VERCEL_TOKEN=
